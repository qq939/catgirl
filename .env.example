# 人兽替换 - 环境变量配置
# 复制此文件为 .env 并填入你的配置
# 系统环境变量优先级更高

# Coze PAT 令牌（必填）
# 获取方式: https://www.coze.cn/open/oauth/pats → 添加新令牌 → 勾选所有权限
COZE_API_KEY=your_coze_pat_token_here

# Coze 工作流 ID（必填）
# 获取方式: 在 coze.cn 打开你的工作流，浏览器地址栏中的 ID
# 例如: https://www.coze.cn/space/xxx/project-ide/xxx/workflow/7461817035346149427
COZE_WORKFLOW_ID=your_workflow_id_here

# 服务端口（可选，默认8082）
PORT=8082
